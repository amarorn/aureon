# Backend
NODE_ENV=development
DEFAULT_TENANT_ID=
PORT=3001
API_PREFIX=api/v1

# Autenticação (JWT + sessões)
# Em dev, vazio usa segredo interno; em produção defina um valor longo e aleatório.
JWT_SECRET=
# true = permite X-Tenant-Id sem login (apenas desenvolvimento legado)
AUTH_LEGACY_TENANT=true
# Webhook opcional: aviso de novo cadastro (Slack/Teams)
INTERNAL_SIGNUP_WEBHOOK_URL=
PUBLIC_APP_URL=http://localhost:3000
# Seed: npm run seed — cria platform_admin se definido
PLATFORM_ADMIN_EMAIL=j.amarone@aureon.com.br
PLATFORM_ADMIN_PASSWORD=N@@r$1715116

# PostgreSQL (transacional)
DB_HOST=localhost
DB_PORT=5433
DB_USER=aureon
DB_PASSWORD=aureon
DB_NAME=aureon
# false = nao logar SQL no console (development)
DB_LOGGING=true

# Redis
REDIS_URL=redis://localhost:6379

# Kafka/Redpanda (event streaming)
KAFKA_BROKERS=localhost:9092

# ClickHouse (analítico)
CLICKHOUSE_URL=http://localhost:8123

# OpenSearch
OPENSEARCH_NODE=http://localhost:9200

# Frontend (opcional)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_TENANT_ID=
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# CORS - origens permitidas (separadas por virgula)
# Ex: CORS_ORIGIN=http://localhost:3000,https://aureon-rose.vercel.app
CORS_ORIGIN=

# Automação: tarefas criadas por workflow (contact_created, opportunity_created, etc.)
# true = workflows com acao create_task criam tarefas; false ou vazio = nao criam (evita milhares de "Tarefa automática")
WORKFLOW_CREATE_TASK_ENABLED=

# Integrações OAuth
# Fallback global quando o tenant NAO tem oauthConfig na tabela tenants (cada cliente pode ter app proprio).
# Por tenant: PUT /integrations/oauth-credentials com X-Tenant-Id — ver docs/TENANT_OAUTH.md
# INTEGRATION_GOOGLE_CLIENT_ID + SECRET: usado por Calendar e demais Google se nao houver variavel especifica abaixo
INTEGRATION_GOOGLE_CLIENT_ID=
INTEGRATION_GOOGLE_CLIENT_SECRET=
# Opcional: se definido, sobrescreve o CLIENT_ID so para esse provider (ex.: Calendar usaria este em vez do global)
# INTEGRATION_GOOGLE_CALENDAR_CLIENT_ID=
# Se definido, sobrescreve CLIENT_ID so para Google Analytics
INTEGRATION_GOOGLE_ANALYTICS_CLIENT_ID=
INTEGRATION_GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
INTEGRATION_GOOGLE_ADS_CLIENT_ID=
# Token de desenvolvedor (Centro de API Google Ads) — necessario para consultas via API
GOOGLE_ADS_DEVELOPER_TOKEN=
INTEGRATION_FACEBOOK_ADS_APP_ID=
INTEGRATION_FACEBOOK_ADS_APP_SECRET=

# LinkedIn OAuth — app em developers.linkedin.com → Auth → Redirect URL = {API_BASE_URL}/{API_PREFIX}/integrations/oauth/callback
# Produto: "Sign in with LinkedIn using OpenID Connect" (r_liteprofile/r_basicprofile deprecados desde 2023)
INTEGRATION_LINKEDIN_CLIENT_ID=
INTEGRATION_LINKEDIN_CLIENT_SECRET=
# true = adiciona escopo r_marketing_leadgen_automation. Depois: desconectar e conectar LinkedIn de novo.
# Lead Sync aprovado no app + PUT .../linkedin/leadgen-config com ownerUrn — ver docs/INTEGRACAO_LINKEDIN.md
# INTEGRATION_LINKEDIN_LEADGEN_SCOPES=true
INTEGRATION_LINKEDIN_LEADGEN_SCOPES=

# RD Station Marketing OAuth
INTEGRATION_RD_STATION_CLIENT_ID=
INTEGRATION_RD_STATION_CLIENT_SECRET=

# Zoom OAuth — marketplace.zoom.us → criar app OAuth, redirect = {API_BASE_URL}/{API_PREFIX}/integrations/oauth/callback
INTEGRATION_ZOOM_CLIENT_ID=
INTEGRATION_ZOOM_CLIENT_SECRET=

# Team notifications
INTEGRATION_SLACK_WEBHOOK_URL=
INTEGRATION_MICROSOFT_TEAMS_WEBHOOK_URL=
CRM_ALERTS_OVERDUE_SCAN_MS=300000

# Email delivery
# Se ambos estiverem configurados, EMAIL_DELIVERY_PROVIDER define a prioridade: sendgrid | amazon_ses
EMAIL_DELIVERY_PROVIDER=
INTEGRATION_SENDGRID_API_KEY=
INTEGRATION_SENDGRID_FROM_EMAIL=
INTEGRATION_SENDGRID_FROM_NAME=
INTEGRATION_SENDGRID_REPLY_TO_EMAIL=
INTEGRATION_AMAZON_SES_ACCESS_KEY_ID=
INTEGRATION_AMAZON_SES_SECRET_ACCESS_KEY=
INTEGRATION_AMAZON_SES_REGION=
INTEGRATION_AMAZON_SES_FROM_EMAIL=
INTEGRATION_AMAZON_SES_FROM_NAME=
INTEGRATION_AMAZON_SES_REPLY_TO_EMAIL=
INTEGRATION_AMAZON_SES_CONFIGURATION_SET=

# Assinatura eletrônica
# Prioridade automática quando ambos estiverem configurados: SIGNATURE_PROVIDER=clicksign|docusign
SIGNATURE_PROVIDER=
INTEGRATION_CLICKSIGN_ACCESS_TOKEN=
INTEGRATION_CLICKSIGN_BASE_URL=https://sandbox.clicksign.com
INTEGRATION_DOCUSIGN_ACCESS_TOKEN=
INTEGRATION_DOCUSIGN_ACCOUNT_ID=
INTEGRATION_DOCUSIGN_BASE_PATH=https://demo.docusign.net
INTEGRATION_DOCUSIGN_RETURN_URL=

# Observabilidade
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Instagram DM — Meta for Developers → app → Instagram Messaging product
# Instagram Business Account ID (GET /{page-id}?fields=instagram_business_account)
INSTAGRAM_IG_USER_ID=
# Page Access Token with instagram_basic, instagram_manage_messages, pages_messaging
INSTAGRAM_PAGE_ACCESS_TOKEN=
# Webhook verify token — must match value set in Meta App Dashboard → Webhooks
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=aureon_instagram_verify
